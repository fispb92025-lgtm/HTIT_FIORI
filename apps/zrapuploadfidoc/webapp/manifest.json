{
  "_version": "1.80.0",
  "sap.app": {
    "id": "zrapuploadfidoc",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "1cde57b5-fa28-4432-a799-b16c5ebb220e"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zrap_ui_data_fidoc_o4/srvd/sap/zrap_ui_data_fidoc/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "zrapuploadfidoc-display": {
          "semanticObject": "zrapuploadfidoc",
          "action": "display",
          "title": "{{zrapuploadfidoc-display.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.142.10",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "zrapuploadfidoc.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "DataDocumentList",
          "target": "DataDocumentList"
        },
        {
          "pattern": "DataDocument({key}):?query:",
          "name": "DataDocumentObjectPage",
          "target": "DataDocumentObjectPage"
        }
      ],
      "targets": {
        "DataDocumentList": {
          "type": "Component",
          "id": "DataDocumentList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/DataDocument",
              "variantManagement": "Page",
              "navigation": {
                "DataDocument": {
                  "detail": {
                    "route": "DataDocumentObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "GridTable",
                    "selectionLimit": 0
                  },
                  "actions": {
                    "ListReportExt": {
                      "press": ".extension.zrapuploadfidoc.ext.controller.ListReportExt.UploadFile",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "Upload File"
                    },
                    "Post_Document": {
                      "press": ".extension.zrapuploadfidoc.ext.controller.ListReportExt.Post_Document",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "Post Document"
                    }
                  }
                }
              }
            }
          }
        },
        "DataDocumentObjectPage": {
          "type": "Component",
          "id": "DataDocumentObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/DataDocument"
            }
          }
        }
      }
    },
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ListReport.ListReportController": {
            "controllerName": "zrapuploadfidoc.ext.controller.ListReportExt"
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
